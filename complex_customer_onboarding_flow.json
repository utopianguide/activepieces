        "sourceCode": {
          "packageJson": "{\"dependencies\": {\"validator\": \"^13.11.0\", \"dayjs\": \"^1.11.0\", \"lodash\": \"^4.17.21\"}}",
          "code": "const validator = require('validator');\nconst dayjs = require('dayjs');\nconst _ = require('lodash');\n\nexport const code = async (inputs) => {\n  const { customerData } = inputs;\n  \n  // Validate required fields\n  const errors = [];\n  if (!customerData.email || !validator.isEmail(customerData.email)) {\n    errors.push('Invalid email address');\n  }\n  \n  if (!customerData.name || customerData.name.length < 2) {\n    errors.push('Name must be at least 2 characters');\n  }\n  \n  if (!customerData.company) {\n    errors.push('Company name is required');\n  }\n  \n  // Determine customer tier based on plan\n  const tierMapping = {\n    'starter': 'bronze',\n    'professional': 'silver', \n    'enterprise': 'gold',\n    'custom': 'platinum'\n  };\n  \n  const customerTier = tierMapping[customerData.plan?.toLowerCase()] || 'bronze';\n  \n  // Calculate onboarding timeline\n  const onboardingDays = {\n    'bronze': 3,\n    'silver': 5,\n    'gold': 7,\n    'platinum': 10\n  };\n  \n  const completionDate = dayjs().add(onboardingDays[customerTier], 'day').toISOString();\n  \n  return {\n    isValid: errors.length === 0,\n    errors,\n    enrichedCustomer: {\n      ...customerData,\n      tier: customerTier,\n      onboardingCompletionDate: completionDate,\n      signupDate: dayjs().toISOString(),\n      status: 'onboarding',\n      priority: customerTier === 'platinum' || customerTier === 'gold' ? 'high' : 'normal'\n    }\n  };\n};"
        },
        "input": {
          "customerData": "{{trigger.body}}"
        },
        "inputUiInfo": {
          "customizedInputs": {}
        },
        "errorHandlingOptions": {
          "continueOnFailure": {
            "value": false
          },
          "retryOnFailure": {
            "value": true
          }
        }
      },
      "nextAction": {
        "name": "validation_router",
        "type": "ROUTER",
        "valid": true,
        "displayName": "Route Based on Data Validation",
        "settings": {
          "executionType": "EXECUTE_FIRST_MATCH",
